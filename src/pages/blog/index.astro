---
import BlogFeedMinimal from "~/components/blocks/BlogFeedMinimal.astro";
import Newsletter from "~/components/blocks/Newsletter.astro";
import Hero from "~/components/blocks/Hero.astro";
import PageLayout from "~/layouts/PageLayout.astro";
---

<PageLayout title="Blog" spacing="lg">
  <section class="space-y-16">
    <Hero
      compact
      pill="Ludi Blog"
      title="Guides, news & updates from Ludi"
      description="Tips, product updates, and team collaboration insights from the Ludi team."
    />
  </section>
  <section>
    <BlogFeedMinimal tag="all" />
  </section>
  <Newsletter />
</PageLayout>
